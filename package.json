{
  "name": "tarkov-map",
  "version": "1.0.1",
  "description": "逃离塔科夫互动地图",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev:web": "yarn --cwd web dev",
    "dev:server": "node src/index.js",
    "dev": "concurrently -n web,server -c cyan,magenta \"yarn:dev:web\" \"yarn:dev:server\"",
    "build:web": "yarn --cwd web build",
    "build": "node scripts/build-all.js",
    "preview": "yarn --cwd web preview",
    "lint": "yarn --cwd web lint",
    "fix": "yarn --cwd web fix",
    "start": "node src/index.js",
    "i:all": "yarn install && yarn --cwd web install"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.11.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16"
  }
}
