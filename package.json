{
  "name": "tarkov-map",
  "version": "1.0.1",
  "description": "逃离塔科夫互动地图 (前后端整合 monorepo)",
  "private": true,
  "main": "src/index.js",
  "scripts": {
    "dev:web": "npm run dev --prefix web",
    "dev:server": "node src/index.js",
    "dev": "concurrently -n web,server -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "build": "npm run build --prefix web",
    "build:all": "node scripts/build-all.js",
    "preview": "npm run preview --prefix web",
    "lint": "npm run lint --prefix web",
    "fix": "npm run fix --prefix web",
    "start": "node src/index.js",
    "install:all": "npm install && npm install --prefix web"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.11.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=16"
  }
}
